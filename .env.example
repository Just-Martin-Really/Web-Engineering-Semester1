# Environment Configuration
# For local setup, no need to change anything here.

# Server Configuration
NODE_ENV=development
PORT=3001

# Database Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/mongo-app

# JWT Token Secrets
# Should be strong and unique for prod, doesnt matter here
ACCESS_TOKEN_SECRET=your-access-token-secret-change-this-in-production
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-this-in-production
SESSION_SECRET=your-session-secret-change-this-in-production

# Token Expiry Times
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Logging
LOG_LEVEL=info

# CORS Configuration (production)
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://futuredomain.com,https://www.futuredomain.com

# Security
# has to be false for local development
ENFORCE_HTTPS=false

# Session Configuration
SESSION_TIMEOUT=7d

# Rate Limiting (requests per window)
GENERAL_RATE_LIMIT=100
AUTH_RATE_LIMIT=5
REFRESH_RATE_LIMIT=10

# Account Lockout
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
RESET_FAILURES_AFTER_MINUTES=60

