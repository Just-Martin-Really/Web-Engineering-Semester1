extends layout
include mixins

block content
  nav.navbar.bg-body.border-bottom.shadow-sm
    .container
      +brand("/")
      .ms-auto
        +themeToggle

  main.container.py-5
    .row.justify-content-center
      .col-lg-7
        .card.border-0.shadow-brand.rounded-4.text-center
          .card-body.p-5
            p.display-1.fw-bold.text-brand.mb-2 404
            h1.h4.fw-bold.mb-3 Seite nicht gefunden
            p.text-body-secondary.mb-4 Die Seite „#{path}“ gibt es hier nicht.
            a.btn.btn-primary.btn-lg(href="/") Zur Startseite
