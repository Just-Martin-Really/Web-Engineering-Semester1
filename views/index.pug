extends layout

block head
  link(rel="stylesheet", href="/homepage.css")
  link(rel="stylesheet", href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Poppins:wght@500;600;700&display=swap")
  script(src="/homepage.js", defer)

block content
  // nav sektion
  header.header
    section.left-header
      img.logo(src="/logoreal.png")
      h2.title Fredforum
    section.right-header
      nav
        ul
          li
            a(href="#HomeThumbnail") Home
          li
            a(href="#aboutUs") About Us
          li
            a(href="#kontakt") Kontakt

  main
    // Home section
    section.thumbnail#HomeThumbnail
      article.hero-image
        img.photoThumbnail(src="/book.jpg")
      article.thumbnailContent
        h1 Willkommen im Kursforum
        a.buttonToLogin(href="#loginRegister") Login

    // about us section
    section.AboutUs-box1#aboutUs
      article.About-image1.reveal-left
        img.AboutusImage(src="/aboutUs.jpg")
      article.AboutusContent1.reveal
        h3.AboutusTitle About us
        p
          | Wir sind vier Informatikstudenten, die eine gemeinsame Überzeugung teilen: Technologie sollte den Alltag bereichern. Als wir im Rahmen eines Schulprojekts vor der Aufgabe standen, etwas Neues zu entwickeln, war unser persönlicher Wunsch sofort klar: Wir wollten etwas sinnvolles entwickeln, das einen bleibenden Wert und einen echten Nutzen für uns alle hat.

    section.AboutUs-box2
      article.AboutusContent2.reveal-left
        h4.AboutUsSmallTitle Ein Kursforum
        p
          | Oft fehlt der richtige Ort für den Austausch unter Komillitonen. Wir haben uns gefragt, wie man die Kommunikation zwischen uns Studierenden einfacher und lebendiger gestalten könnte. Unser Ziel war es, eine Plattform zu bauen, die den Austausch von Interessen erleichter und als zentrale Anlaufstelle für Fragen und Antworten dient.
          | Das Kursforum sollte ein Schritt in eine vernetztere Gemeinschaft werden.
        h4.AboutUsSmallTitle Nachhaltigkeit
        p
          | Mit dem Kursforum haben wir die Hoffnung etwas zu entwickelt, dass sich fortgehend weiterentwickelt und auch noch nützlich für weitere Studiengänge sein könnte.
      article.About-image2.reveal-right
        img.AboutusImage(src="/img/AboutUsBild2.jpg")

    // login section
    section.login-box#loginRegister
      article.login-boxContent.reveal-left
        h1 Login
        form#loginForm
          .input-box
            input#textLoginBenutzerName.inputField(type="text", name="loginBenutzername", placeholder="Benutzername", required)
          .input-box
            input#textLoginBenutzerPasswort.inputField(type="password", name="loginPasswort", placeholder="Passwort", required)
          button#buttonLogin.buttonLogin(type="submit") Anmelden
        .register-link
          p
            | Du hast keinen Account?
            a(href="/register")  Registrieren
      article.photo-robot.reveal-right
        img.robot-image(src="/robot.png")
        .welcome-text Willkommen!

  // footer kontakt section
  footer.footer-section#kontakt
    section.footer-container
      article.footer-column
        h4 Kontakt
        p Du hast einen Bug gefunden oder Feedback?
        a.bug-report-btn(href="https://www.youtube.com/watch?v=dQw4w9WgXcQ", target="_blank", rel="noopener noreferrer") Kontaktformular

      article.footer-column
        h4 Pages
        ul
          li
            a(href="#HomeThumbnail") Home
          li
            a(href="#aboutUs") About Us
          li
            a(href="#loginRegister") Login and Registration

    section.footer-bottom
      article
        p Kursforum - designed by Amica Martin Stefan Tamara

  script(src="/utils.js")
  script(src="/app.js")

